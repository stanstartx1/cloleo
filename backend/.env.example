# Copier vers backend/.env (ne pas committer .env)
# cp .env.example .env   (Linux/macOS)
# copy .env.example .env (Windows)

# MongoDB — local ou Atlas
MONGO_URL=mongodb://localhost:27017
DB_NAME=cloleo

# JWT — utiliser une valeur fixe en dev pour éviter les déconnexions au redémarrage
JWT_SECRET=change-me-use-openssl-rand-hex-32

# Compte admin local (connexion sans entrée en base, voir routes/auth.py)
LOCAL_ADMIN_EMAIL=admin@cloleo.com
LOCAL_ADMIN_PASSWORD=change-me-local-admin
LOCAL_ADMIN_NAME=Admin Cloleo
